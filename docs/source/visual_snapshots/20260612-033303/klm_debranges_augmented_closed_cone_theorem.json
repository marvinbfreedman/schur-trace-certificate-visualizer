{
  "theoremName": "augmented closed-cone KLM-to-de Branges bridge theorem",
  "hardyJson": "klm_debranges_canonical_hardy_image.json",
  "pullbackLimitJson": "klm_debranges_augmented_pullback_limit.json",
  "augmentedContinuumJson": "xi_augmented_trace_continuum_lift.json",
