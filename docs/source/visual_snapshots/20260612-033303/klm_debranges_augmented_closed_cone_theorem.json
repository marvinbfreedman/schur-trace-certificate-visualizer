  "statuses": {
    "canonicalHardyStatus": {
      "label": "canonical Hardy/de Branges identity",
      "closed": true,
      "status": "closed",
      "reason": "The shifted-Xi de Branges kernel equals the signed Hardy branch Gram K_E=<h^+,h^+>-<h^-,h^->."
    },
    "finiteThetaAugmentedPullbackStatus": {
      "label": "finite theta augmented pullbacks",
      "closed": true,
      "status": "closed",
      "reason": "For each theta truncation Xi_N, the exact Mellin split gives h_{z,N}^\\pm = boundary(Mu_{z,N}^\\pm)+tail_{z,N}^\\pm.  The imported sample verification shows the signed Gram of these augmented pullbacks agrees with the direct de Branges Gram to the displayed tolerance."
    },
    "continuumAugmentedRepairStatus": {
      "label": "continuum augmented trace repair",
      "closed": true,
      "status": "closed",
      "reason": "The continuum augmented repair theorem proves Mu is a closed trace coordinate, D_aug is bounded and nonnegative in the transported trace norm, and K+R_aug^*D_aug R_aug is a closed positive form."
    },
    "uniformThetaTailStatus": {
      "label": "uniform compact theta-tail convergence",
      "closed": true,
      "status": "closed",
      "reason": "For |Im z|<=M, the n-th theta atom is bounded by C_M n^4 exp(-pi n^2/2).  Indeed, for v>=0, exp(-pi n^2 e^v)<=exp(-pi n^2/2)exp(-pi e^v/2), and the remaining v-integral is finite uniformly on the compact strip.  The Weierstrass M-test gives Xi_N->Xi uniformly on compact shifted z-sets, hence the branch Gram entries converge uniformly on finite test sets."
    },
    "closedPositiveConeStatus": {
      "label": "closed positive-cone limit",
      "closed": true,
      "status": "closed",
      "reason": "For each finite test set, positive semidefinite Gram matrices form a closed cone.  Entrywise convergence of the finite augmented KLM pullback Grams to K_E therefore preserves positivity."
    },
    "allOmegaKlmInputStatus": {
      "label": "all-omega KLM/Weyl positivity input",
      "closed": true,
      "status": "closed",
      "reason": "Imported from uniform_omega_weyl_klm_bridge.json."
    },
    "klmToDeBrangesBridgeStatus": {
      "label": "KLM-to-de Branges closed-cone bridge",
      "closed": true,
      "status": "closed",
      "reason": "The finite augmented KLM pullbacks converge entrywise to the shifted-Xi de Branges kernel.  Since each finite pullback is in the KLM positive cone and the cone is closed on finite Gram matrices, K_E is positive on every finite evaluation set."
    }
  },
